class Solution {
public:
    vector<string> buildArray(vector<int>& target, int n) {
        vector<string>result;
        int i = 0;

        for(int num = 1; i<=n ; num++){
            result.push_back("Push");

            if(num == target[i]){
                i++;
            }else{
                result.push_back("Pop");
            }

            if(i==target.size()){
                break;
            }
        }

    return result;     
    }
};
